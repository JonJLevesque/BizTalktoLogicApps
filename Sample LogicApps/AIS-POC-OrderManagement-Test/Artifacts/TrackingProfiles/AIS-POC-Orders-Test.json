{
  "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2024-03-31/trackingdefinitionschema.json#",
  "businessProcess": {
    "correlationPropertyName": "OrderId",
    "name": "AIS-POC-Orders-Test",
    "version": "@{parameters('VersionForBusinessProcess-AIS-POC-Orders-Test')}"
  },
  "trackingDefinitions": {
    "IncomingOrder": {
      "events": {
        "Order_Processed": {
          "statuses": {
            "success": {
              "operationName": "Process_Order",
              "operationType": "Action",
              "properties": {
                "OrderId": "@body('Parse_Order')?['OrderId']"
              }
            }
          }
        },
        "Order_Received": {
          "statuses": {
            "success": {
              "operationName": "Acknowledge_Order",
              "operationType": "Action",
              "properties": {
                "OrderId": "@body('Parse_Order')?['OrderId']"
              }
            }
          }
        },
        "Order_Shipped": {
          "statuses": {
            "success": {
              "operationName": "Ship_Order",
              "operationType": "Action",
              "properties": {
                "OrderId": "@body('Parse_Order')?['OrderId']"
              }
            }
          }
        }
      }
    },
    "OutgoingOrder": {
      "events": {
        "Order_Delivery_Confirmed": {
          "statuses": {
            "success": {
              "operationName": "Order_Delivery_Received",
              "operationType": "Action",
              "properties": {
                "OrderId": "@body('Parse_Order')?['OrderId']"
              }
            }
          }
        },
        "Order_Placed": {
          "statuses": {
            "success": {
              "operationName": "Publish_Order_Request",
              "operationType": "Action",
              "properties": {
                "OrderId": "@body('Parse_Order')?['OrderId']"
              }
            }
          }
        }
      }
    },
    "RequestFeedback": {
      "events": {
        "Feedback_Received": {
          "statuses": {
            "success": {
              "operationName": "Feedback_Received",
              "operationType": "Action",
              "properties": {
                "OrderId": "@triggerBody()?['OrderId']"
              }
            }
          }
        },
        "Request_Feedback": {
          "statuses": {
            "success": {
              "operationName": "Request_Feedback",
              "operationType": "Action",
              "properties": {
                "OrderId": "@triggerBody()?['OrderId']"
              }
            }
          }
        },
        "Send_Feedback_for_AI_Analysis": {
          "statuses": {
            "success": {
              "operationName": "Send_Feedback_For_AI_Analysis",
              "operationType": "Action",
              "properties": {
                "OrderId": "@triggerBody()?['OrderId']"
              }
            }
          }
        }
      }
    },
    "SendFeedback": {
      "events": {
        "Feedback_Sent_by_Cx": {
          "statuses": {
            "success": {
              "operationName": "SendFeedback",
              "operationType": "Action",
              "properties": {
                "OrderId": "@triggerBody()?['OrderId']"
              }
            }
          }
        }
      }
    }
  }
}
