{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://biztalk-to-logicapps/schemas/migration-schema.json",
  "title": "MigrationResult",
  "description": "Complete output of a BizTalk application migration analysis. Produced by Stage 1 (Understand) and Stage 2 (Document). Consumed by Stage 3 (Build).",
  "type": "object",
  "required": ["schemaVersion", "analysisDate", "biztalkApplication", "integrationIntent", "migrationPlan"],
  "additionalProperties": false,
  "properties": {

    "schemaVersion": {
      "type": "string",
      "description": "Schema version for forward-compatibility checks",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "example": "1.0.0"
    },

    "analysisDate": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the analysis was performed"
    },

    "biztalkApplication": {
      "type": "object",
      "description": "Metadata about the source BizTalk application",
      "required": ["name", "artifacts"],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "biztalkVersion": {
          "type": "string",
          "enum": ["2010", "2013", "2013R2", "2016", "2020", "unknown"],
          "description": "BizTalk Server version the application was deployed on"
        },
        "artifacts": {
          "type": "object",
          "properties": {
            "orchestrations": {
              "type": "array",
              "items": { "$ref": "#/definitions/OrchestrationArtifact" }
            },
            "maps": {
              "type": "array",
              "items": { "$ref": "#/definitions/MapArtifact" }
            },
            "pipelines": {
              "type": "array",
              "items": { "$ref": "#/definitions/PipelineArtifact" }
            },
            "schemas": {
              "type": "array",
              "items": { "$ref": "#/definitions/SchemaArtifact" }
            },
            "bindings": {
              "type": "array",
              "items": { "$ref": "#/definitions/BindingArtifact" }
            }
          }
        },
        "complexityScore": {
          "type": "integer",
          "minimum": 0,
          "description": "Computed complexity score. 0-10=Simple, 11-25=Moderate, 26-50=Complex, 51+=HighlyComplex"
        },
        "complexityClassification": {
          "type": "string",
          "enum": ["simple", "moderate", "complex", "highly-complex"]
        }
      }
    },

    "integrationIntent": {
      "$ref": "#/definitions/IntegrationIntent",
      "description": "Extracted business intent — the shared intermediate representation consumed by the Build stage"
    },

    "migrationPlan": {
      "type": "object",
      "description": "Structured migration specification produced by Stage 2 (Document)",
      "required": ["summary", "componentMappings", "gapAnalysis", "architectureRecommendation"],
      "properties": {
        "summary": {
          "type": "string",
          "description": "Plain English summary of what this integration does and the recommended migration approach"
        },
        "componentMappings": {
          "type": "array",
          "items": { "$ref": "#/definitions/ComponentMigrationMapping" }
        },
        "gapAnalysis": {
          "type": "object",
          "properties": {
            "gaps": {
              "type": "array",
              "items": { "$ref": "#/definitions/MigrationGap" }
            },
            "overallRisk": {
              "type": "string",
              "enum": ["low", "medium", "high", "critical"]
            },
            "estimatedEffortDays": {
              "type": "number",
              "description": "Estimated total migration effort in person-days"
            }
          }
        },
        "architectureRecommendation": {
          "$ref": "#/definitions/ArchitectureRecommendation"
        },
        "manualInterventionPoints": {
          "type": "array",
          "description": "Specific things the consultant must review, decide, or implement manually",
          "items": {
            "type": "object",
            "required": ["description", "severity"],
            "properties": {
              "description": { "type": "string" },
              "severity": { "type": "string", "enum": ["info", "warning", "required"] },
              "artifactRef": { "type": "string", "description": "Reference to specific artifact (e.g., orchestration name or shape ID)" }
            }
          }
        }
      }
    },

    "generatedArtifacts": {
      "type": "object",
      "description": "Logic Apps artifacts generated by Stage 3 (Build). Populated after build stage runs.",
      "properties": {
        "workflows": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "content"],
            "properties": {
              "name": { "type": "string" },
              "filePath": { "type": "string" },
              "content": {
                "type": "object",
                "description": "Complete Logic Apps workflow.json content (Workflow Definition Language)"
              },
              "sourceOrchestration": { "type": "string" }
            }
          }
        },
        "maps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "format", "content"],
            "properties": {
              "name": { "type": "string" },
              "format": { "type": "string", "enum": ["xslt", "lml", "liquid"] },
              "filePath": { "type": "string" },
              "content": { "type": "string" },
              "sourceMap": { "type": "string" }
            }
          }
        },
        "connections": {
          "type": "object",
          "description": "connections.json content",
          "properties": {
            "serviceProviderConnections": { "type": "object" },
            "managedApiConnections": { "type": "object" }
          }
        },
        "appSettings": {
          "type": "object",
          "description": "App settings keys required (values are placeholders — never store actual credentials here)",
          "additionalProperties": { "type": "string" }
        },
        "infrastructure": {
          "type": "object",
          "description": "ARM or Bicep template for deployment",
          "properties": {
            "format": { "type": "string", "enum": ["arm", "bicep"] },
            "content": { "type": "string" }
          }
        },
        "testSpecs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "workflowName": { "type": "string" },
              "testCases": { "type": "array", "items": { "type": "object" } }
            }
          }
        }
      }
    }
  },

  "definitions": {

    "IntegrationIntent": {
      "type": "object",
      "description": "Shared intermediate representation — both migration (Mode A) and NLP greenfield (Mode B) produce this. The Build stage consumes it.",
      "required": ["trigger", "steps", "errorHandling", "systems", "dataFormats", "patterns", "metadata"],
      "properties": {
        "trigger": {
          "type": "object",
          "required": ["type", "source", "connector", "config"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["polling", "webhook", "schedule", "manual"]
            },
            "source": { "type": "string", "description": "Human description, e.g. 'SFTP server', 'Service Bus queue'" },
            "connector": { "type": "string", "description": "Logic Apps connector ID, e.g. 'sftp', 'serviceBus', 'request'" },
            "config": {
              "type": "object",
              "additionalProperties": true,
              "description": "Connector-specific config: frequency, path, queue name, etc."
            }
          }
        },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/definitions/IntegrationStep" }
        },
        "errorHandling": {
          "type": "object",
          "required": ["strategy"],
          "properties": {
            "strategy": {
              "type": "string",
              "enum": ["retry", "dead-letter", "compensate", "terminate", "notify", "ignore"]
            },
            "retryPolicy": {
              "type": "object",
              "properties": {
                "count": { "type": "integer", "minimum": 1, "maximum": 90 },
                "interval": { "type": "string", "description": "ISO 8601 duration, e.g. PT10S" },
                "type": { "type": "string", "enum": ["fixed", "exponential", "none"] }
              }
            },
            "deadLetterTarget": { "type": "string" },
            "notificationTarget": { "type": "string" },
            "compensationWorkflow": { "type": "string" }
          }
        },
        "systems": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "protocol", "role", "authentication"],
            "properties": {
              "name": { "type": "string" },
              "protocol": { "type": "string" },
              "role": { "type": "string", "enum": ["source", "destination", "intermediate", "error-handler"] },
              "authentication": { "type": "string", "enum": ["managed-identity", "api-key", "basic", "oauth", "connection-string", "certificate", "none", "unknown"] },
              "onPremises": { "type": "boolean" },
              "requiresGateway": { "type": "boolean" }
            }
          }
        },
        "dataFormats": {
          "type": "object",
          "required": ["input", "output"],
          "properties": {
            "input": { "type": "string", "enum": ["xml", "json", "csv", "flat-file", "edi-x12", "edi-edifact", "as2", "binary", "text", "unknown"] },
            "output": { "type": "string", "enum": ["xml", "json", "csv", "flat-file", "edi-x12", "edi-edifact", "as2", "binary", "text", "unknown"] },
            "schemas": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "description": "JSON Schema object for a named message type"
              }
            }
          }
        },
        "patterns": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "content-based-routing",
              "sequential-convoy",
              "scatter-gather",
              "publish-subscribe",
              "request-reply",
              "message-aggregator",
              "message-enricher",
              "dead-letter-queue",
              "retry-idempotent",
              "claim-check",
              "process-manager",
              "message-filter",
              "splitter",
              "wire-tap",
              "fan-out",
              "correlation"
            ]
          }
        },
        "metadata": {
          "type": "object",
          "required": ["source", "complexity"],
          "properties": {
            "source": { "type": "string", "enum": ["biztalk-migration", "nlp-greenfield"] },
            "complexity": { "type": "string", "enum": ["simple", "moderate", "complex"] },
            "estimatedActions": { "type": "integer" },
            "requiresIntegrationAccount": { "type": "boolean" },
            "requiresOnPremGateway": { "type": "boolean" }
          }
        }
      }
    },

    "IntegrationStep": {
      "type": "object",
      "required": ["id", "type", "description"],
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": [
            "transform", "route", "enrich", "validate", "send", "receive",
            "aggregate", "split", "delay", "invoke-child", "invoke-function",
            "set-variable", "error-handler", "condition", "loop", "parallel"
          ]
        },
        "description": { "type": "string" },
        "connector": { "type": "string", "description": "Logic Apps connector ID if this step uses a specific connector" },
        "actionType": { "type": "string", "description": "Logic Apps action type, e.g. Http, ServiceProvider, If, Foreach" },
        "config": { "type": "object", "additionalProperties": true },
        "runAfter": {
          "type": "array",
          "items": { "type": "string" },
          "description": "IDs of steps that must complete before this one runs"
        }
      }
    },

    "OrchestrationArtifact": {
      "type": "object",
      "required": ["name", "filePath"],
      "properties": {
        "name": { "type": "string" },
        "filePath": { "type": "string" },
        "namespace": { "type": "string" },
        "shapes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "shapeType": { "type": "string" },
              "shapeId": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "ports": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "polarity": { "type": "string", "enum": ["Implements", "Uses"] },
              "portType": { "type": "string" }
            }
          }
        },
        "correlationSets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "correlationProperties": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "hasTransactions": { "type": "boolean" },
        "hasCompensation": { "type": "boolean" },
        "hasBRECalls": { "type": "boolean" }
      }
    },

    "MapArtifact": {
      "type": "object",
      "required": ["name", "filePath"],
      "properties": {
        "name": { "type": "string" },
        "filePath": { "type": "string" },
        "sourceSchema": { "type": "string" },
        "destinationSchema": { "type": "string" },
        "hasScriptingFunctoids": { "type": "boolean" },
        "hasLooping": { "type": "boolean" },
        "functoidCategories": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["string", "math", "logical", "date-time", "conversion", "scientific", "cumulative", "database", "advanced", "scripting"]
          }
        },
        "linkCount": { "type": "integer" },
        "recommendedMigrationPath": {
          "type": "string",
          "enum": ["lml", "xslt", "xslt-rewrite", "azure-function", "manual"]
        }
      }
    },

    "PipelineArtifact": {
      "type": "object",
      "required": ["name", "filePath", "direction"],
      "properties": {
        "name": { "type": "string" },
        "filePath": { "type": "string" },
        "direction": { "type": "string", "enum": ["receive", "send"] },
        "components": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "componentType": { "type": "string" },
              "stage": { "type": "string" },
              "isCustom": { "type": "boolean" }
            }
          }
        }
      }
    },

    "SchemaArtifact": {
      "type": "object",
      "required": ["name", "filePath"],
      "properties": {
        "name": { "type": "string" },
        "filePath": { "type": "string" },
        "rootNode": { "type": "string" },
        "targetNamespace": { "type": "string" },
        "isPropertySchema": { "type": "boolean" },
        "isEDISchema": { "type": "boolean" }
      }
    },

    "BindingArtifact": {
      "type": "object",
      "required": ["name", "filePath"],
      "properties": {
        "name": { "type": "string" },
        "filePath": { "type": "string" },
        "receivePorts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "adapterType": { "type": "string" },
              "address": { "type": "string" },
              "pipeline": { "type": "string" }
            }
          }
        },
        "sendPorts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "adapterType": { "type": "string" },
              "address": { "type": "string" },
              "pipeline": { "type": "string" },
              "filterExpression": { "type": "string" }
            }
          }
        }
      }
    },

    "ComponentMigrationMapping": {
      "type": "object",
      "required": ["sourceComponent", "sourceType", "migrationStatus", "targetComponent"],
      "properties": {
        "sourceComponent": { "type": "string", "description": "Name of the BizTalk component" },
        "sourceType": {
          "type": "string",
          "enum": ["shape", "adapter", "pipeline-component", "functoid", "artifact"]
        },
        "migrationStatus": {
          "type": "string",
          "enum": ["direct", "partial", "none"],
          "description": "direct=1:1 mapping, partial=workaround needed, none=redesign required"
        },
        "targetComponent": { "type": "string", "description": "Logic Apps equivalent" },
        "targetType": {
          "type": "string",
          "enum": ["trigger", "action", "connector", "expression", "azure-function", "pattern", "not-applicable"]
        },
        "configNotes": { "type": "string" },
        "estimatedEffort": {
          "type": "string",
          "enum": ["trivial", "low", "medium", "high", "very-high"]
        }
      }
    },

    "MigrationGap": {
      "type": "object",
      "required": ["capability", "severity", "description", "mitigation"],
      "properties": {
        "capability": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "description": { "type": "string" },
        "mitigation": { "type": "string" },
        "estimatedEffortDays": { "type": "number" },
        "affectedArtifacts": { "type": "array", "items": { "type": "string" } }
      }
    },

    "ArchitectureRecommendation": {
      "type": "object",
      "required": ["targetSku", "workflowCount"],
      "properties": {
        "targetSku": { "type": "string", "enum": ["standard", "consumption", "standard-hybrid"] },
        "workflowCount": { "type": "integer" },
        "requiresIntegrationAccount": { "type": "boolean" },
        "integrationAccountTier": { "type": "string", "enum": ["free", "basic", "standard"] },
        "requiresOnPremGateway": { "type": "boolean" },
        "requiresVnetIntegration": { "type": "boolean" },
        "azureServicesRequired": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "logic-apps-standard", "service-bus", "event-hubs", "event-grid",
              "azure-functions", "cosmos-db", "blob-storage", "key-vault",
              "application-insights", "api-management", "azure-relay",
              "integration-account", "on-prem-data-gateway"
            ]
          }
        },
        "estimatedMonthlyCost": {
          "type": "object",
          "properties": {
            "currency": { "type": "string" },
            "low": { "type": "number" },
            "high": { "type": "number" }
          }
        }
      }
    }
  }
}
