      "notes": "No native flat file disassembler. Implement parsing logic in Azure Functions (.NET or Node.js).",
      "effort": "medium"
    },
    "XMLValidator": {
      "component": "XML Validator",
      "stage": "Validate",
      "direction": "receive",
