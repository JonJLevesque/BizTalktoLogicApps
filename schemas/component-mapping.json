      "direction": "receive",
      "migrationStatus": "direct",
      "logicAppsEquivalent": "HTTP Request trigger body (XML parsed via xpath() or Parse XML)",
      "notes": "No explicit disassembly step needed — Logic Apps actions work with raw body.",
      "effort": "trivial"
    },
    "FlatFileDisassembler": {
      "component": "Flat File Disassembler",
      "stage": "Disassemble",
      "direction": "receive",
