{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "version": "1.0.0",
  "lastUpdated": "2026-02-23",
  "description": "Machine-readable component mapping data. Used by the TypeScript migration engine to look up BizTalk components and get their Logic Apps equivalents.",

  "shapes": {
    "description": "BizTalk orchestration shape → Logic Apps action mapping",
    "Receive_Activating": {
      "biztalkName": "Receive (activating)",
      "odxShapeType": "ReceiveShape",
      "odxActivating": true,
      "migrationStatus": "direct",
      "logicAppsEquivalent": "Trigger",
      "logicAppsType": "trigger",
      "connectorSelectionRule": "use-adapter-connector-mapping",
      "notes": "Polarity=Implements + Activate=true → workflow trigger. Connector depends on bound adapter.",
      "effort": "trivial"
    },
    "Receive_NonActivating": {
      "biztalkName": "Receive (correlated)",
      "odxShapeType": "ReceiveShape",
      "odxActivating": false,
      "migrationStatus": "partial",
      "logicAppsEquivalent": "ServiceProvider action (SB receive) or HTTP wait with callback URL",
      "logicAppsType": "action",
      "notes": "Correlation must be handled via Service Bus sessions or HTTP callback URL pattern. No native correlated receive in Logic Apps.",
      "effort": "medium"
    },
    "Send_OneWay": {
      "biztalkName": "Send (one-way)",
      "odxShapeType": "SendShape",
      "migrationStatus": "direct",
      "logicAppsEquivalent": "HTTP action or ServiceProvider action",
      "logicAppsType": "action",
      "connectorSelectionRule": "use-adapter-connector-mapping",
      "notes": "Map bound send port adapter → connector. Address → connector endpoint config.",
      "effort": "trivial"
    },
    "Send_RequestReply": {
      "biztalkName": "Send (solicited receive / request-reply)",
      "odxShapeType": "SendShape",
      "migrationStatus": "direct",
      "logicAppsEquivalent": "HTTP action (response captured in body())",
      "logicAppsType": "action",
      "notes": "Synchronous call. Response available as body('ActionName').",
      "effort": "low"
    },
    "ConstructMessage": {
      "biztalkName": "Construct Message",
      "odxShapeType": "ConstructShape",
      "migrationStatus": "direct",
      "logicAppsEquivalent": "Compose action (container for construction logic)",
      "logicAppsType": "action",
      "notes": "Construct Message shape is a container. Inner MessageAssignment/Transform shapes determine the action.",
      "effort": "trivial"
    },
    "MessageAssignment": {
      "biztalkName": "Message Assignment",
      "odxShapeType": "MessageAssignmentShape",
      "migrationStatus": "direct",
      "logicAppsEquivalent": "Compose action or Set Variable action",
      "logicAppsType": "action",
      "notes": "MsgOut = MsgIn → Compose with inputs: @{triggerBody()}. Field assignment → Compose with expression object.",
      "effort": "low",
      "expressionTranslationRequired": true
    },
    "Transform": {
      "biztalkName": "Transform",
      "odxShapeType": "TransformShape",
      "migrationStatus": "direct",
      "logicAppsEquivalent": "Transform action (XSLT or Data Mapper LML)",
      "logicAppsType": "action",
      "notes": "References .btm map → convert map to XSLT or LML. Check for msxsl:script (scripting functoids) — may require Azure Function.",
      "effort": "medium",
      "mapConversionRequired": true
    },
    "Decide": {
      "biztalkName": "Decide",
      "odxShapeType": "DecisionShape",
      "migrationStatus": "direct",
      "logicAppsEquivalent": "If action (2 branches) or Switch action (N branches)",
      "logicAppsType": "action",
      "notes": "XLANG/s condition → WDL expression. ==→equals, &&→and, ||→or, !→not. See expression-mapping.md.",
      "effort": "low",
      "expressionTranslationRequired": true
    },
    "Loop": {
      "biztalkName": "Loop",
      "odxShapeType": "LoopShape",
      "migrationStatus": "direct",
      "logicAppsEquivalent": "Until action",
      "logicAppsType": "action",
      "notes": "BizTalk Loop condition is entry condition (while). Until runs body THEN checks condition — invert the condition.",
      "effort": "low",
      "conditionInversionRequired": true
    },
    "ForEach": {
      "biztalkName": "ForEach (over message collection)",
      "odxShapeType": "LoopShape",
      "migrationStatus": "partial",
      "logicAppsEquivalent": "ForEach action",
      "logicAppsType": "action",
      "notes": "BizTalk envelope debatching vs LA ForEach iteration. Parse XML/JSON array first, then ForEach.",
      "effort": "medium"
    },
    "Listen": {
      "biztalkName": "Listen",
      "odxShapeType": "ListenShape",
      "migrationStatus": "partial",
      "logicAppsEquivalent": "Multiple triggers / Event Grid fan-out",
      "logicAppsType": "pattern",
      "notes": "First event wins. Requires separate receiver workflows per channel feeding a common processor via Service Bus or Event Grid.",
      "effort": "medium"
    },
    "Delay": {
      "biztalkName": "Delay",
      "odxShapeType": "DelayShape",
      "migrationStatus": "direct",
      "logicAppsEquivalent": "Delay action or Delay Until action",
      "logicAppsType": "action",
      "notes": "System.TimeSpan(h,m,s) → ISO 8601 PT{n}H{n}M{n}S. Absolute time → Delay Until with @{addHours(utcNow(), N)}.",
      "effort": "low"
    },
    "Suspend": {
      "biztalkName": "Suspend",
      "odxShapeType": "SuspendShape",
      "migrationStatus": "none",
      "logicAppsEquivalent": "No equivalent. Terminate with failure or manual intervention required.",
      "logicAppsType": "not-applicable",
      "notes": "BizTalk Suspend puts orchestration in suspended queue for manual resubmit. Logic Apps has no equivalent. Design: Terminate + DLQ + resubmit workflow.",
      "effort": "high"
    },
    "Terminate": {
      "biztalkName": "Terminate",
      "odxShapeType": "TerminateShape",
      "migrationStatus": "direct",
      "logicAppsEquivalent": "Terminate action",
      "logicAppsType": "action",
      "notes": "status='Failed' for error termination, 'Cancelled' for business-rule cancellation.",
      "effort": "trivial"
    },
    "Throw": {
      "biztalkName": "Throw",
      "odxShapeType": "ThrowShape",
      "migrationStatus": "direct",
      "logicAppsEquivalent": "Terminate action (status: Failed)",
      "logicAppsType": "action",
      "notes": "throw new System.Exception(msg) → Terminate action with runStatus=Failed and error message.",
      "effort": "trivial"
    },
    "ParallelActions": {
      "biztalkName": "Parallel Actions",
      "odxShapeType": "ParallelActionsShape",
      "migrationStatus": "direct",
      "logicAppsEquivalent": "Multiple actions with same runAfter predecessor",
      "logicAppsType": "pattern",
      "notes": "Actions in WDL run concurrently when they share the same runAfter dependency. No explicit parallel container needed.",
      "effort": "low"
    },
    "Scope_Exception": {
      "biztalkName": "Scope (exception handling)",
      "odxShapeType": "ScopeShape",
      "odxTransactionType": "None",
      "migrationStatus": "direct",
      "logicAppsEquivalent": "Scope action with runAfter:FAILED catch actions",
      "logicAppsType": "action",
      "notes": "Scope action contains try-body. Catch actions have runAfter: {ScopeName: [FAILED]}. Use result() to get error details.",
      "effort": "low"
    },
    "Scope_LongRunning": {
      "biztalkName": "Scope (long-running transaction)",
      "odxShapeType": "ScopeShape",
      "odxTransactionType": "LongRunning",
      "migrationStatus": "partial",
      "logicAppsEquivalent": "Scope action + stateful workflow + compensation workflow design",
      "logicAppsType": "pattern",
      "notes": "Logic Apps Standard stateful workflow provides equivalent durability. Compensation must be designed explicitly.",
      "effort": "medium"
    },
    "Scope_Atomic": {
      "biztalkName": "Scope (atomic transaction)",
      "odxShapeType": "ScopeShape",
      "odxTransactionType": "Atomic",
      "migrationStatus": "none",
      "logicAppsEquivalent": "No equivalent. Requires Saga or Outbox pattern redesign.",
      "logicAppsType": "pattern",
      "notes": "MSDTC atomic scope has no Logic Apps equivalent. Redesign using Saga (compensating transactions) or Outbox pattern. See gap-analysis.md.",
      "effort": "very-high"
    },
    "Compensate": {
      "biztalkName": "Compensate",
      "odxShapeType": "CompensateShape",
      "migrationStatus": "none",
      "logicAppsEquivalent": "No equivalent. Explicit compensation actions in catch scope.",
      "logicAppsType": "not-applicable",
      "notes": "Must design compensation logic explicitly as actions in the Scope catch branch. No automatic rollback.",
      "effort": "very-high"
    },
    "CallOrchestration": {
      "biztalkName": "Call Orchestration",
      "odxShapeType": "CallOrchestrationShape",
      "migrationStatus": "direct",
      "logicAppsEquivalent": "Workflow action (type: Workflow) — Standard SKU only",
      "logicAppsType": "action",
      "wdlActionType": "Workflow",
      "notes": "Synchronous child workflow call. host.workflow.id = child workflow name in same Logic Apps resource.",
      "effort": "low"
    },
    "StartOrchestration": {
      "biztalkName": "Start Orchestration",
      "odxShapeType": "StartOrchestrationShape",
      "migrationStatus": "direct",
      "logicAppsEquivalent": "Service Bus send (fire-and-forget) or HTTP action to trigger URL",
      "logicAppsType": "action",
      "notes": "Async fire-and-forget. Publish to Service Bus queue/topic → separate consumer workflow. Or HTTP POST to child workflow trigger URL.",
      "effort": "low"
    },
    "CallRules": {
      "biztalkName": "Call Rules (BRE)",
      "odxShapeType": "CallRulesShape",
      "migrationStatus": "partial",
      "logicAppsEquivalent": "If/Switch inline conditions or Azure Functions (for complex rules)",
      "logicAppsType": "action",
      "notes": "Simple rules → inline If/Switch. Complex BRE hierarchies → Azure Functions with rule logic or Azure Rules Engine. See gap-analysis.md.",
      "effort": "high"
    },
    "Expression": {
      "biztalkName": "Expression",
      "odxShapeType": "ExpressionShape",
      "migrationStatus": "direct",
      "logicAppsEquivalent": "Set Variable action or Initialize Variable action",
      "logicAppsType": "action",
      "notes": "Variable assignment expressions → SetVariable. New variable declarations → InitializeVariable in trigger inputs.",
      "effort": "low",
      "expressionTranslationRequired": true
    }
  },

