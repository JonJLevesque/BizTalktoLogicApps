      "effort": "medium"
    }
  },

  "functoids": {
    "description": "BizTalk map functoid → Logic Apps / WDL expression equivalent. FID = Functoid ID range.",
    "categories": {
      "string": {
        "fid_range": "104-165",
        "mappings": {
          "StringConcat": { "fid": 104, "wdlEquivalent": "concat(s1, s2, ...)", "effort": "trivial" },
          "StringFind": { "fid": 105, "wdlEquivalent": "indexOf(text, substring)", "effort": "trivial" },
          "StringLeft": { "fid": 106, "wdlEquivalent": "substring(text, 0, length)", "effort": "low" },
          "StringRight": { "fid": 107, "wdlEquivalent": "substring(text, sub(length(text), n))", "effort": "low" },
          "StringLength": { "fid": 108, "wdlEquivalent": "length(text)", "effort": "trivial" },
          "StringToLower": { "fid": 109, "wdlEquivalent": "toLower(text)", "effort": "trivial" },
          "StringToUpper": { "fid": 110, "wdlEquivalent": "toUpper(text)", "effort": "trivial" },
          "StringTrimLeft": { "fid": 111, "wdlEquivalent": "trimStart(text)", "effort": "trivial" },
          "StringTrimRight": { "fid": 112, "wdlEquivalent": "trimEnd(text)", "effort": "trivial" },
          "StringExtract": { "fid": 113, "wdlEquivalent": "substring(text, start, length)", "effort": "low" },
          "SizeOf": { "fid": 150, "wdlEquivalent": "length(string(value))", "effort": "low" }
        }
      },
      "math": {
        "fid_range": "200-265",
        "mappings": {
          "Addition": { "fid": 200, "wdlEquivalent": "add(x, y)", "effort": "trivial" },
          "Subtraction": { "fid": 201, "wdlEquivalent": "sub(x, y)", "effort": "trivial" },
          "Multiplication": { "fid": 202, "wdlEquivalent": "mul(x, y)", "effort": "trivial" },
          "Division": { "fid": 203, "wdlEquivalent": "div(x, y)", "effort": "trivial" },
          "Modulo": { "fid": 204, "wdlEquivalent": "mod(x, y)", "effort": "trivial" },
          "Absolute Value": { "fid": 205, "wdlEquivalent": "abs(value) — not in WDL core; use Azure Functions or max(x, mul(-1, x))", "effort": "low" },
          "Integer": { "fid": 206, "wdlEquivalent": "int(value)", "effort": "trivial" },
