        [Microsoft.XLANGs.BaseTypes.LogicalBinding()]
        port uses PortTypeOut Port_Out;
        message AutoMergeInput InputMessage;
        message AutoMergeOut OuputMessage;
        MCH.SZ.UniversoAutoMerge.Biztalk.Support.AllUniversoAutoMergeResponse allUniversoAutoMergeResponse;
        System.Guid traceToken;
        System.String xmlAutoMergeResponse;
        MCH.SZ.UniversoAutoMerge.Biztalk.Support.UniversoAutoMergeResponse universoAutoMergeResponse;
        System.Xml.XmlDocument autoMergeInput;
        MCH.SZ.UniversoAutoMerge.Biztalk.Support.Entry fileRow;
        System.String fileName;
        System.Int32 index;
        System.Int32 nTotalCards;
        System.Guid CorrelationId;
        body ()
        {
            [Microsoft.XLANGs.BaseTypes.DesignerPosition("c9547f98-5cc5-4fd0-a55e-a4484313be5b")]
            activate ((BTS.MessageType exists))receive (Port_In.Operation_1, InputMessage);
            allUniversoAutoMergeResponse = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.AllUniversoAutoMergeResponse();
            xmlAutoMergeResponse = "";
            universoAutoMergeResponse = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.UniversoAutoMergeResponse();
            autoMergeInput = new System.Xml.XmlDocument();
            fileRow = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.Entry();
            fileName = "";
            [Microsoft.XLANGs.BaseTypes.DesignerPosition("f3cb27be-86c5-4a7e-907e-07ea07a42355")]
            traceToken =  Microsoft.BizTalk.CAT.BestPractices.Framework.Instrumentation.TraceManager.WorkflowComponent.TraceIn();
            [Microsoft.XLANGs.BaseTypes.DesignerPosition("d9704baf-fc29-4abf-8b1a-05b25f01333e")]
            Microsoft.BizTalk.CAT.BestPractices.Framework.Instrumentation.TraceManager.WorkflowComponent.TraceWarning(
                System.String.Format(
                    "Bizdirect.CMC.BizTalk.UniversoAutoMerge.AutoMerge - Input Message: {0}",
                    Vantyx.CMC.SystemCommon.Serialization.SerializeToString(InputMessage)        
                )
            );
            [Microsoft.XLANGs.BaseTypes.DesignerPosition("9f6543b3-fd55-401b-b8fb-08857b861ce3")]
            fileName = InputMessage(FILE.ReceivedFileName);
            CorrelationId = System.Guid.NewGuid();
            
            autoMergeInput = InputMessage;
            
            index = 0; 
            
            // total number of rows in .txt file to be proccessed -- System.Convert.ToInt32( xpath(InputMessage, "count(" + xPathAutoMergeRoot + "/CardUniverso2Merge)"));
            nTotalCards = MCH.SZ.UniversoAutoMerge.Biztalk.Support.XmlSupport.GetNumberOfMergeToDo(autoMergeInput);
            
            Microsoft.BizTalk.CAT.BestPractices.Framework.Instrumentation.TraceManager.WorkflowComponent.TraceInfo(
                System.String.Format(
                    "Bizdirect.CMC.BizTalk.UniversoAutoMerge.AutoMereg - Begin merge process. {0} file entries to proccess.",
                    nTotalCards.ToString()
                )
            );
            
            allUniversoAutoMergeResponse = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.AllUniversoAutoMergeResponse();
            [Microsoft.XLANGs.BaseTypes.DesignerPosition("cfdc0de3-01e5-4831-952f-4cedbec68fad")]
            scope
            {
                System.Boolean SZMergeSucceedOnVLL;
                System.Boolean MCHMergeSucceedOnVLL;
                MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountRequest mergeRequest;
                MCH.SZ.UniversoAutoMerge.Biztalk.Support.AutoMergeReponse autoMergeResponseSzVLL;
                MCH.SZ.UniversoAutoMerge.Biztalk.Support.AutoMerge autoMergeReponseSz;
                MCH.SZ.UniversoAutoMerge.Biztalk.Support.AutoMergeReponse autoMergeResponseMchVll;
                MCH.SZ.UniversoAutoMerge.Biztalk.Support.AutoMerge autoMergeReponseMch;
                MCH.SZ.UniversoAutoMerge.Biztalk.Support.AccountInfo accountSrc;
                MCH.SZ.UniversoAutoMerge.Biztalk.Support.AccountInfo accountDst;
                MCH.SZ.UniversoAutoMerge.Biztalk.Support.Error Error;
                System.Boolean checkSum;
                System.String mchDestinationLoyalty;
                System.String szDestinationLoyalty;
                System.String szSourceLoyalty;
                System.String mchSourceLoyalty;
                System.Boolean hasErrorFile;
                System.String mchDestinationLoyaltyPortal;
                System.String mchSourceLoyaltyPortal;
                System.String szDestinationLoyaltyPortal;
                System.String szSourceLoyaltyPortal;
                body
                {
                    SZMergeSucceedOnVLL = false;
                    MCHMergeSucceedOnVLL = false;
                    mergeRequest = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountRequest();
                    autoMergeResponseSzVLL = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.AutoMergeReponse();
                    autoMergeReponseSz = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.AutoMerge();
                    autoMergeResponseMchVll = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.AutoMergeReponse();
                    autoMergeReponseMch = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.AutoMerge();
                    accountSrc = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.AccountInfo();
                    accountDst = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.AccountInfo();
                    Error = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.Error();
                    checkSum = true;
                    mchDestinationLoyalty = "";
                    szDestinationLoyalty = "";
                    szSourceLoyalty = "";
                    mchSourceLoyalty = "";
                    hasErrorFile = true;
                    mchDestinationLoyaltyPortal = "";
                    mchSourceLoyaltyPortal = "";
                    szDestinationLoyaltyPortal = "";
                    szSourceLoyaltyPortal = "";
                    [Microsoft.XLANGs.BaseTypes.DesignerPosition("75fa32fb-dc90-4d47-af7f-148039f9453d")]
                    while (nTotalCards > index)
                    {
                        [Microsoft.XLANGs.BaseTypes.DesignerPosition("75b5fa77-8f5c-41f7-aff2-964670fa72c1")]
                        // init response object
                        universoAutoMergeResponse = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.UniversoAutoMergeResponse();
                        universoAutoMergeResponse.AutoMergeMCH = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.AutoMerge();
                        universoAutoMergeResponse.AutoMergeSZ = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.AutoMerge();
                        
                         universoAutoMergeResponse.SrcCard = fileRow.SourceNr;
                        
                        universoAutoMergeResponse.DstCard = fileRow.DestinationNr; 
                        CorrelationId = System.Guid.NewGuid();
                        hasErrorFile = false;
                        
                        
                        // INIT VARS
                        fileRow = MCH.SZ.UniversoAutoMerge.Biztalk.Support.XmlSupport.GetUniversoCardsToMerge(InputMessage, index, ref checkSum, ref universoAutoMergeResponse, CorrelationId);
                        
                        Microsoft.BizTalk.CAT.BestPractices.Framework.Instrumentation.TraceManager.WorkflowComponent.TraceInfo(
                            System.String.Format(
                                "Bizdirect.CMC.BizTalk.UniversoAutoMerge.AutoMerge - Source Card {0} and Destination Card {1} about to be processed.", fileRow.SourceNr, fileRow.DestinationNr
                            )
                        );
                        [Microsoft.XLANGs.BaseTypes.DesignerPosition("274285ff-e416-47da-acee-0e35220f396e")]
                        if (!checkSum)
                        {
                            [Microsoft.XLANGs.BaseTypes.DesignerPosition("07c4757f-2456-4ae4-84f5-6180b40bc556")]
                            mchSourceLoyalty = MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountSupport.checkIfPrimaryCRMMCH(fileRow.SourceNr, CorrelationId, fileName);
                            mchDestinationLoyalty = MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountSupport.checkIfPrimaryCRMMCH(fileRow.DestinationNr, CorrelationId, fileName);
                            
                            szSourceLoyalty = MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountSupport.checkIfPrimaryCRMSZ(fileRow.SourceNr, CorrelationId, fileName);
                            szDestinationLoyalty = MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountSupport.checkIfPrimaryCRMSZ(fileRow.DestinationNr, CorrelationId, fileName);
                            //------------------------------------------------------------------------------------------
                            mchSourceLoyaltyPortal = MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountSupport.checkIfPrimaryPortalMCH(fileRow.SourceNr, CorrelationId, fileName);
                            mchDestinationLoyaltyPortal = MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountSupport.checkIfPrimaryPortalMCH(fileRow.DestinationNr, CorrelationId, fileName);
                            
                            szSourceLoyaltyPortal = MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountSupport.checkIfPrimaryPortalSZ(fileRow.SourceNr, CorrelationId, fileName);
                            szDestinationLoyaltyPortal = MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountSupport.checkIfPrimaryPortalSZ(fileRow.DestinationNr, CorrelationId, fileName);
                            [Microsoft.XLANGs.BaseTypes.DesignerPosition("cda4ecfb-11e9-48b0-88f5-f4b894745d8b")]
                            if (!System.String.IsNullOrEmpty(mchSourceLoyalty) || !System.String.IsNullOrEmpty(mchDestinationLoyalty) || 
                                !System.String.IsNullOrEmpty(szSourceLoyalty) || !System.String.IsNullOrEmpty(szDestinationLoyalty)  ||
                                
                                !System.String.IsNullOrEmpty(mchSourceLoyaltyPortal) || !System.String.IsNullOrEmpty(mchDestinationLoyaltyPortal) ||
                                !System.String.IsNullOrEmpty(szSourceLoyaltyPortal) || !System.String.IsNullOrEmpty(szDestinationLoyaltyPortal))
                            {
                                [Microsoft.XLANGs.BaseTypes.DesignerPosition("6ffbceac-f68e-49b7-8dd8-e613f3bbbb31")]
                                // init MergeRequest object for MCH  
                                mergeRequest = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountRequest();
                                mergeRequest.DestinationCardNumber = fileRow.DestinationNr;
                                mergeRequest.SourceCardNumber = fileRow.SourceNr;
                                mergeRequest.Ensign = MCH.SZ.UniversoAutoMerge.Biztalk.Support.SystemEnsign.MCH;
                                
                                autoMergeReponseMch = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.AutoMerge();
                                autoMergeReponseMch.CRM = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.AutoMergeReponse();
                                autoMergeReponseMch.VLL = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.AutoMergeReponse();
                                autoMergeReponseMch.Portal = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.AutoMergeReponse();
                                
                                
                                [Microsoft.XLANGs.BaseTypes.DesignerPosition("4f2645bd-b4fb-4533-a9ed-0a431cf81adf")]
                                if (!System.String.IsNullOrWhiteSpace(fileRow.DestinationNr) 
                                    && !System.String.IsNullOrWhiteSpace(fileRow.SourceNr) && 
                                    fileRow.SourceNr != fileRow.DestinationNr)
                                {
                                    [Microsoft.XLANGs.BaseTypes.DesignerPosition("d5382601-ee5b-4e38-a141-24ce44bb2b75")]
                                    accountSrc = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.AccountInfo();
                                    accountDst = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.AccountInfo();
                                    accountSrc = MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountSupport.GetInfosUniversoAccountNumber(fileRow.SourceNr,
                                        MCH.SZ.UniversoAutoMerge.Biztalk.Support.SystemEnsign.MCH,CorrelationId);
                                    
                                    accountDst = MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountSupport.GetInfosUniversoAccountNumber(fileRow.DestinationNr, 
                                        MCH.SZ.UniversoAutoMerge.Biztalk.Support.SystemEnsign.MCH,CorrelationId);
                                    [Microsoft.XLANGs.BaseTypes.DesignerPosition("73ffd353-ecbf-4d0b-9962-0044a9bd26d8")]
                                    if (accountDst.GetAccountInfoStatus == MCH.SZ.UniversoAutoMerge.Biztalk.Support.OperationStatus.Failed
                                        || 
                                        accountSrc.GetAccountInfoStatus == MCH.SZ.UniversoAutoMerge.Biztalk.Support.OperationStatus.Failed)
                                    {
                                        [Microsoft.XLANGs.BaseTypes.DesignerPosition("b1cf7376-edec-4dd1-b1a7-6498bfe88f1a")]
                                        
                                        // VLL
                                        autoMergeReponseMch.VLL = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.AutoMergeReponse();
                                        autoMergeReponseMch.VLL.Result = MCH.SZ.UniversoAutoMerge.Biztalk.Support.OperationStatus.Failed.ToString();
                                        autoMergeReponseMch.VLL.Message = System.String.Format("VLL Retrieve returned with errors: Source Card {0} - Destination Card {1}", fileRow.SourceNr, fileRow.DestinationNr);
                                        
                                        autoMergeReponseSz.VLL = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.AutoMergeReponse();
                                        autoMergeReponseSz.VLL = autoMergeReponseMch.VLL;
                                        
                                        // CRM
                                        autoMergeReponseMch.CRM = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.AutoMergeReponse();
                                        autoMergeReponseMch.CRM.Result = MCH.SZ.UniversoAutoMerge.Biztalk.Support.OperationStatus.Failed.ToString();
                                        autoMergeReponseMch.CRM.Message = System.String.Format("VLL Retrieve returned with errors: Source Card {0} - Destination Card {1}",  fileRow.SourceNr, fileRow.DestinationNr);
                                        
                                        autoMergeReponseSz.CRM = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.AutoMergeReponse();
                                        autoMergeReponseSz.CRM = autoMergeReponseMch.CRM;
                                        
                                        // Portal
                                        autoMergeReponseMch.Portal = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.AutoMergeReponse();
                                        autoMergeReponseMch.Portal.Result = MCH.SZ.UniversoAutoMerge.Biztalk.Support.OperationStatus.Failed.ToString();
                                        autoMergeReponseMch.Portal.Message = System.String.Format("VLL Retrieve returned with errors: Source Card {0} - Destination Card {1}",  fileRow.SourceNr, fileRow.DestinationNr);
                                        
                                        autoMergeReponseSz.Portal = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.AutoMergeReponse();
                                        autoMergeReponseSz.Portal = autoMergeReponseMch.Portal;
                                        
                                        universoAutoMergeResponse.AutoMergeMCH = autoMergeReponseMch;
                                        universoAutoMergeResponse.AutoMergeSZ = autoMergeReponseSz;
                                        
                                        
                                        // write error to database
                                        if (accountDst.Error != null){
                                            MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountSupport.WriteErrorLog(accountDst.Error, fileName);
                                        }
                                        
                                        if(accountSrc.Error != null){
                                        MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountSupport.WriteErrorLog(accountSrc.Error, fileName);
                                        }
                                        [Microsoft.XLANGs.BaseTypes.DesignerPosition("4fc238fe-045f-41a9-809e-27707e217ed8")]
                                        if(!hasErrorFile){
                                            if(nTotalCards ==  index - 1)
                                            {
                                                MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountSupport.WriteToFile(
                                                fileRow.SourceNr,  fileRow.SourceNif, fileRow.DestinationNr, fileRow.DestinationNif,
                                                CorrelationId, true, fileName);
                                            }
                                            else{
                                                MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountSupport.WriteToFile(
                                                fileRow.SourceNr, fileRow.SourceNif, fileRow.DestinationNr, fileRow.DestinationNif,
                                                CorrelationId, false, fileName);
                                            }
                                            hasErrorFile = true;
                                        }
                                    }
                                    else 
                                    {
                                        [Microsoft.XLANGs.BaseTypes.DesignerPosition("492452ae-c60b-490e-9598-9a75b052e0b2")]
                                        if (System.String.Compare(accountDst.CardNumber, accountSrc.CardNumber) == 0)
                                        {
                                            [Microsoft.XLANGs.BaseTypes.DesignerPosition("62da4d52-0cf9-4499-91b8-64667cf20510")]
                                            autoMergeResponseMchVll = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.AutoMergeReponse();
                                            autoMergeResponseMchVll.Result = MCH.SZ.UniversoAutoMerge.Biztalk.Support.OperationStatus.Success.ToString();
                                            autoMergeResponseMchVll.Message = "VLL Merge já foi efectuado on MCH";
                                            
                                            autoMergeReponseMch.VLL = autoMergeResponseMchVll;
                                            
                                            universoAutoMergeResponse.AutoMergeMCH.VLL= autoMergeResponseMchVll;
                                            
                                            // mark operation as Succeed
                                            MCHMergeSucceedOnVLL = true;
                                        }
                                        else 
                                        {
                                            [Microsoft.XLANGs.BaseTypes.DesignerPosition("5a0d135f-48fa-405c-824b-bb58ac04726c")]
                                            MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountSupport.ActivateTemporaryCard(fileRow.SourceNr,CorrelationId,fileName);
                                            [Microsoft.XLANGs.BaseTypes.DesignerPosition("c35b49d5-71c6-4a4a-8be0-2aee97c4a22d")]
                                            scope
                                            {
                                                MCH.SZ.UniversoAutoMerge.Biztalk.Support.Error mchError;
                                                body
                                                {
                                                    mchError = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.Error();
                                                    [Microsoft.XLANGs.BaseTypes.DesignerPosition("efc7dd8b-f4a7-4f62-a86e-d200e4779377")]
                                                    scope
                                                    {
                                                        MCH.SZ.UniversoAutoMerge.Biztalk.Support.AutoMergeReponse autoMergeReponseMchVll;
                                                        MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountResponse mergeResponse;
                                                        MCH.SZ.UniversoAutoMerge.Biztalk.Support.Error error;
                                                        body
                                                        {
                                                            autoMergeReponseMchVll = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.AutoMergeReponse();
                                                            mergeResponse = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountResponse();
                                                            error = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.Error();
                                                            [Microsoft.XLANGs.BaseTypes.DesignerPosition("c7d349c2-a2fc-4995-9932-0901338680dc")]
                                                            if (MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountSupport.mergeCheck(mchSourceLoyalty, mchDestinationLoyalty, fileName, CorrelationId))
                                                            {
                                                                [Microsoft.XLANGs.BaseTypes.DesignerPosition("505e492d-8b71-44e8-bf46-bf277ca5caec")]
                                                                autoMergeReponseMch.VLL.Result = MCH.SZ.UniversoAutoMerge.Biztalk.Support.OperationStatus.Success.ToString();
                                                                autoMergeReponseMch.VLL.Message = "Merge Succeeded";
                                                                
                                                                mergeResponse.MergeResultStatus = MCH.SZ.UniversoAutoMerge.Biztalk.Support.OperationStatus.Success;
                                                                
                                                                universoAutoMergeResponse.AutoMergeMCH.VLL = autoMergeReponseMch.VLL;
                                                                
                                                                // mark operation as Succeed
                                                                MCHMergeSucceedOnVLL = true;
                                                            }
                                                            else 
                                                            {
                                                                [Microsoft.XLANGs.BaseTypes.DesignerPosition("35ed7e74-3db2-45d1-828c-7412a4d5e9a5")]
                                                                // perform the merge VLL 
                                                                mergeResponse = MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountSupport.MergeAccountVLL(mergeRequest,CorrelationId);
                                                                
                                                                
                                                                
                                                                [Microsoft.XLANGs.BaseTypes.DesignerPosition("b06759d3-88dd-4ea5-aa14-9319da596786")]
                                                                if (mergeResponse.MergeResultStatus == MCH.SZ.UniversoAutoMerge.Biztalk.Support.OperationStatus.Failed)
                                                                {
                                                                    [Microsoft.XLANGs.BaseTypes.DesignerPosition("05d6655c-ea9c-40ad-8ddc-2785476afa33")]
                                                                    MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountSupport.WriteErrorLog(mergeResponse.Error, fileName);
                                                                    
                                                                    autoMergeReponseMchVll = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.AutoMergeReponse();
                                                                    autoMergeReponseMchVll.Result = mergeResponse.MergeResultStatus.ToString();
                                                                    autoMergeReponseMchVll.Message = System.String.Format("Failure on WebService {0} - WebMethod {1}", mergeResponse.Error.WebService, mergeResponse.Error.WebMethod);
                                                                    
                                                                    autoMergeReponseMch.VLL = autoMergeReponseMchVll;
                                                                    universoAutoMergeResponse.AutoMergeMCH.VLL = autoMergeReponseMchVll;
                                                                    
                                                                    // mark operation as not Succeed
                                                                    MCHMergeSucceedOnVLL = false;
                                                                    [Microsoft.XLANGs.BaseTypes.DesignerPosition("ccf666bb-e735-433f-8be7-9462b39e2e56")]
                                                                    if(!hasErrorFile){
                                                                        if(nTotalCards ==  index - 1)
                                                                        {
                                                                            MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountSupport.WriteToFile(
                                                                            fileRow.SourceNr, fileRow.SourceNif, fileRow.DestinationNr, fileRow.DestinationNif,
                                                                            CorrelationId, true, fileName);
                                                                        }
                                                                        else{
                                                                            MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountSupport.WriteToFile(
                                                                            fileRow.SourceNr, fileRow.SourceNif, fileRow.DestinationNr, fileRow.DestinationNif,
                                                                            CorrelationId, false, fileName);
                                                                        }
                                                                    hasErrorFile = true;
                                                                    }
                                                                }
                                                                else 
                                                                {
                                                                    [Microsoft.XLANGs.BaseTypes.DesignerPosition("8cd38b6c-8399-469a-979a-f4eb30d4e0ee")]
                                                                    autoMergeReponseMchVll = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.AutoMergeReponse();
                                                                    autoMergeReponseMchVll.Result = mergeResponse.MergeResultStatus.ToString();
                                                                    autoMergeReponseMchVll.Message = "VLL Merge já foi feito succeed on MCH";
                                                                    
                                                                    autoMergeReponseMch.VLL = autoMergeReponseMchVll;
                                                                    universoAutoMergeResponse.AutoMergeMCH.VLL = autoMergeReponseMchVll;
                                                                    
                                                                    // mark operation as Succeed
                                                                    MCHMergeSucceedOnVLL = true;
                                                                }
                                                            }
                                                        }
                                                        exceptions
                                                        {
                                                            [Microsoft.XLANGs.BaseTypes.DesignerPosition("5a71fe61-a9e5-4c2c-acfb-ce1392b5ce1c")]
                                                            catch (System.Exception ex)
                                                            {
                                                                [Microsoft.XLANGs.BaseTypes.DesignerPosition("1fed5cc4-e399-43e6-b215-e9526bb9bee7")]
                                                                error = new MCH.SZ.UniversoAutoMerge.Biztalk.Support.Error();
                                                                error.Insignia = "MCH";
                                                                error.Sistema = "VLL";
                                                                error.Message = System.String.Format("Error processing the orchestration that does the merge in the VLL: {0}", ex.Message);
                                                                error.ExceptionType = "";
                                                                error.FaultException = ex.ToString();
                                                                error.WebService = "";
                                                                error.WebMethod = "";
                                                                error.Response = "";
                                                                error.CorrelationId = CorrelationId;
                                                                
                                                                MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountSupport.WriteErrorLog(error, fileName);
                                                                
                                                                // mark operation as not Succeed
                                                                MCHMergeSucceedOnVLL = false;
                                                                [Microsoft.XLANGs.BaseTypes.DesignerPosition("e66b961d-9c93-4d6d-8b56-3cad4f2e87a4")]
                                                                if(!hasErrorFile){
                                                                    if(nTotalCards ==  index - 1)
                                                                    {
                                                                        MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountSupport.WriteToFile(
                                                                        fileRow.SourceNr, fileRow.SourceNif, fileRow.DestinationNr, fileRow.DestinationNif,
                                                                        CorrelationId, true, fileName);
                                                                    }
                                                                    else{
                                                                        MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountSupport.WriteToFile(
                                                                        fileRow.SourceNr, fileRow.SourceNif, fileRow.DestinationNr, fileRow.DestinationNif,
                                                                        CorrelationId, false, fileName);
                                                                    }
                                                                    hasErrorFile = true;
                                                                }
                                                            }
                                                        }
                                                    }
                                                    [Microsoft.XLANGs.BaseTypes.DesignerPosition("53b347da-a355-42cb-abd7-a5cf8192843a")]
                                                    if (MCHMergeSucceedOnVLL == true)
                                                    {
                                                        [Microsoft.XLANGs.BaseTypes.DesignerPosition("f839b0d2-e9a0-4785-9af0-5ecb24c175e5")]
                                                        // alter MergeRequest object for MCH  
                                                        mergeRequest.DestinationCardNumber = accountDst.CardNumber;
                                                        mergeRequest.SourceCardNumber = accountSrc.CardNumber;
                                                        mergeRequest.Ensign = MCH.SZ.UniversoAutoMerge.Biztalk.Support.SystemEnsign.MCH;
                                                        
                                                        
                                                        [Microsoft.XLANGs.BaseTypes.DesignerPosition("b2bfdc77-7e28-4983-aae0-f2ce36e4d3ec")]
                                                        scope
                                                        {
                                                            MCH.SZ.UniversoAutoMerge.Biztalk.Support.AutoMergeReponse autoMergeReponseMchCrm;
                                                            MCH.SZ.UniversoAutoMerge.Biztalk.Support.MergeAccountResponse mergeResponse;
                                                            MCH.SZ.UniversoAutoMerge.Biztalk.Support.Error error;
                                                            body
                                                            {
